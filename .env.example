# Database
POSTGRES_USER=smartcart
POSTGRES_PASSWORD=smartcart_dev
POSTGRES_DB=smartcart
DATABASE_URL=postgres://smartcart:smartcart_dev@postgres:5432/smartcart
# Uncomment to expose postgres on a host port (dev only, never in production)
POSTGRES_EXTERNAL_PORT=5432

# Server
PORT=3001
CLIENT_PORT=8081
CLIENT_URL=http://localhost:8081
JWT_SECRET=your_jwt_secret_here

# Client
VITE_API_URL=http://localhost:3001/api
